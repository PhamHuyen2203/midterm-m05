<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_product_item"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/txtReportCategoryName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#111827"
        android:textSize="17sp"
        android:textStyle="bold"
        tools:text="Nhà Sách Tiki" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="#E5E7EB" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Giá trung bình -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRUNG BÌNH"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAveragePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:textColor="#0B74E5"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="150.000 ₫" />

        </LinearLayout>

        <!-- Giá thấp nhất -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THẤP NHẤT"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLowestPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:textColor="#16A34A"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="25.000 ₫" />

        </LinearLayout>

        <!-- Giá cao nhất -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAO NHẤT"
                android:textColor="#6B7280"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtHighestPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:textColor="#DC2626"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="950.000 ₫" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>