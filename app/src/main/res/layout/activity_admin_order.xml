<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:orientation="vertical"
    tools:context=".AdminOrderActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#111827"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/btnBackAdminOrder"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="ĐƠN HÀNG ĐÃ THANH TOÁN"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnRefreshAdminOrder"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tải lại danh sách"
            android:padding="12dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#FFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/txtAdminOrderSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingTop="11dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        android:text="Đã tải: 0 đơn hàng"
        android:textColor="#4B5563"
        android:textSize="14sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAdminOrder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="10dp"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_admin_order" />

        <ProgressBar
            android:id="@+id/progressAdminOrder"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtEmptyAdminOrder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:padding="24dp"
            android:text="Chưa có đơn hàng đã thanh toán"
            android:textColor="#6B7280"
            android:textSize="16sp"
            android:visibility="gone" />

    </FrameLayout>

    <TextView
        android:id="@+id/txtAdminOrderLoadState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp"
        android:text="Đã tải hết đơn hàng"
        android:textColor="#6B7280"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>